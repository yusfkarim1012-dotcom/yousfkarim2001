<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_bg"
    android:orientation="horizontal"
    android:gravity="center"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:paddingStart="8dp"
    android:paddingEnd="8dp">

    <LinearLayout android:id="@+id/isha_container" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
        android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:id="@+id/isha_label" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="العشاء"
            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:fontFamily="sans-serif-condensed"/>
        <TextView android:id="@+id/isha_time" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="--:--"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:fontFamily="sans-serif-condensed"
            android:paddingTop="3dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/maghrib_container" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
        android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:id="@+id/maghrib_label" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="المغرب"
            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:fontFamily="sans-serif-condensed"/>
        <TextView android:id="@+id/maghrib_time" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="--:--"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:fontFamily="sans-serif-condensed"
            android:paddingTop="3dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/asr_container" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
        android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:id="@+id/asr_label" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="العصر"
            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:fontFamily="sans-serif-condensed"/>
        <TextView android:id="@+id/asr_time" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="--:--"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:fontFamily="sans-serif-condensed"
            android:paddingTop="3dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/dhuhr_container" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
        android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:id="@+id/dhuhr_label" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="الظهر"
            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:fontFamily="sans-serif-condensed"/>
        <TextView android:id="@+id/dhuhr_time" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="--:--"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:fontFamily="sans-serif-condensed"
            android:paddingTop="3dp"/>
    </LinearLayout>

    <LinearLayout android:id="@+id/fajr_container" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:gravity="center"
        android:paddingTop="6dp" android:paddingBottom="6dp">
        <TextView android:id="@+id/fajr_label" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="الفجر"
            android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" android:fontFamily="sans-serif-condensed"/>
        <TextView android:id="@+id/fajr_time" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="--:--"
            android:textColor="#FFFFFF" android:textSize="18sp" android:textStyle="bold" android:fontFamily="sans-serif-condensed"
            android:paddingTop="3dp"/>
    </LinearLayout>
</LinearLayout>
